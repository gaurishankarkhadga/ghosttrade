{
  "manifest_version": 3,
  "name": "Ghosttrade",
  "version": "2.0",
  "description": "Invisible on-demand UI overlay.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Analyze Chart",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.tradingview.com/*",
        "*://*.binance.com/*",
        "*://*.coinbase.com/*",
        "*://*.kucoin.com/*",
        "*://*.bybit.com/*",
        "*://*.okx.com/*",
        "*://*.kraken.com/*",
        "*://*.bitfinex.com/*",
        "*://*.gate.io/*",
        "*://*.mexc.com/*",
        "*://*.investing.com/*",
        "*://*.webull.com/*",
        "*://*.etoro.com/*",
        "*://*.zerodha.com/*",
        "*://*.upstox.com/*",
        "*://*.groww.in/*",
        "*://*.dhan.co/*"
      ],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
