# Ghost Trade Backend Environment Configuration

# Gemini API Key for the vision/analysis pipeline
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/ghosttradeai?retryWrites=true&w=majority

# Name of the database to use
MONGODB_DB_NAME=ghosttrade

# Optional: Port for the WebSocket server (defaults to 5000)
# PORT=5000
